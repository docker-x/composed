#!/usr/bin/env bash
# Pre-commit hook: format and vet staged Go files.
# Install: git config core.hooksPath .githooks
set -euo pipefail

# Ensure Go toolchain is on PATH.
if command -v go &>/dev/null; then
  GOBIN=$(dirname "$(command -v go)")
elif [[ -x "$(go env GOROOT 2>/dev/null)/bin/go" ]]; then
  GOBIN="$(go env GOROOT)/bin"
elif [[ -n "${GOROOT:-}" ]]; then
  GOBIN="$GOROOT/bin"
else
  echo "pre-commit: go not found, skipping hooks"
  exit 0
fi
export PATH="$GOBIN:$PATH"

# Collect staged .go files (excluding deleted).
mapfile -t gofiles < <(git diff --cached --name-only --diff-filter=d -- '*.go')
[[ ${#gofiles[@]} -eq 0 ]] && exit 0

# --- gofmt ---
unformatted=$(gofmt -l "${gofiles[@]}" 2>/dev/null || true)
if [[ -n "$unformatted" ]]; then
  echo "gofmt: formatting staged files..."
  gofmt -w $unformatted
  git add $unformatted
fi

# --- go vet ---
echo "go vet: checking..."
go vet ./...
